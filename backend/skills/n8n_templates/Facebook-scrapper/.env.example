# ============================================================
#  .env.example — Шаблон конфигурации  v4.0
#  !! СКОПИРУЙТЕ в .env и заполните своими данными !!
#  !! Файл .env НИКОГДА не попадёт в репозиторий !!
# ============================================================

# ══════════════════════════════════════════════════════════════
#  ОБЯЗАТЕЛЬНЫЕ
# ══════════════════════════════════════════════════════════════

# ── Путь к User Data папке Chrome ────────────────────────────
#  Windows: chrome://version/ → "Путь к профилю" → убрать \Default
CHROME_USER_DATA_DIR=C:\Users\YourName\AppData\Local\Google\Chrome\User Data

# ── Открытые группы Facebook (через запятую) ─────────────────
GROUP_URLS=https://www.facebook.com/groups/GROUP_ONE,https://www.facebook.com/groups/GROUP_TWO

# ── OpenAI API ключ ──────────────────────────────────────────
#  GenSpark Sandbox: ключ берётся автоматически из ~/.genspark_llm.yaml
#  Иначе: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ══════════════════════════════════════════════════════════════
#  LLM МОДЕЛИ
# ══════════════════════════════════════════════════════════════

# ── Модель для text-анализа (быстрая и дешёвая) ──────────────
LLM_MODEL=gpt-5-mini

# ── Модель для vision-анализа (мультимодальная) ──────────────
#  qwen2.5vl — хорошо читает афиши, шведский/английский/кириллицу
VISION_MODEL=qwen2.5vl

# ── Порог уверенности vision (0.0–1.0) ───────────────────────
#  Ниже порога — событие не включается в результат
VISION_CONFIDENCE_THRESHOLD=0.6

# ── Кастомный base URL (GenSpark, Azure и др.) ───────────────
# OPENAI_BASE_URL=https://www.genspark.ai/api/llm_proxy/v1

# ══════════════════════════════════════════════════════════════
#  СКРЕЙПИНГ
# ══════════════════════════════════════════════════════════════

# ── Постов собирать с каждой группы (диапазон 15–20) ─────────
POSTS_PER_GROUP=20

# ── Итерации скроллинга (больше = глубже, но медленнее) ──────
SCROLL_ITERATIONS=6

# ══════════════════════════════════════════════════════════════
#  ОГРАНИЧЕНИЕ ЗАПУСКОВ (антибан)
# ══════════════════════════════════════════════════════════════

# ── Минимальный интервал между сессиями (часы) ───────────────
#  По умолчанию 22 ч = 1 запуск в сутки
MIN_RUN_INTERVAL_HOURS=22

# ── Принудительный запуск, игнорируя интервал ────────────────
#  ТОЛЬКО ДЛЯ ОТЛАДКИ! В продакшне держать false
FORCE_RUN=false

# ══════════════════════════════════════════════════════════════
#  ЛОКАЛЬ И ВЫВОД
# ══════════════════════════════════════════════════════════════

# ── Локаль браузера ───────────────────────────────────────────
#  sv-SE — шведский (рекомендуется для шведских групп)
#  ru-RU — русский, en-US — английский
LOCALE=sv-SE
TIMEZONE=Europe/Stockholm
ACCEPT_LANGUAGE=sv-SE,sv;q=0.9,en;q=0.8,en-US;q=0.7

# ── Файл результатов ─────────────────────────────────────────
OUTPUT_FILE=events.csv

# ── Файл состояния (seen post URLs, last_run_at) ──────────────
STATE_FILE=state.json

# ── Headless режим ────────────────────────────────────────────
#  false = видимый браузер (рекомендуется при первой настройке)
#  true  = фоновый режим (для автоматических прогонов)
HEADLESS=false

# ══════════════════════════════════════════════════════════════
#  SUPABASE (опционально — без этого только CSV)
# ══════════════════════════════════════════════════════════════

# ── Supabase Project URL ──────────────────────────────────────
#  Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# ── Service Role Key (НЕ anon key!) ──────────────────────────
#  Dashboard → Project Settings → API → service_role secret
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx

# ── Имя таблицы (по умолчанию raw_posts) ─────────────────────
#  DDL для создания таблицы: sql/init.sql
SUPABASE_TABLE=raw_posts

# ══════════════════════════════════════════════════════════════
#  LLM RETRY (отказоустойчивость)
# ══════════════════════════════════════════════════════════════

# ── Максимум повторных попыток при ошибках API ────────────────
#  RateLimitError: 30s × attempt | Vision: 45s × attempt
#  APITimeoutError / ConnectionError: 5s × attempt
#  5xx Server Error: 10s × attempt
LLM_MAX_RETRIES=3
