{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "http://localhost:5000",
    "distDir": "../ui",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Agent n8On",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true,
        "execute": false,
        "sidecar": false
      },
      "window": {
        "all": true
      },
      "process": {
        "all": false,
        "exit": true,
        "relaunch": true
      },
      "notification": {
        "all": true
      },
      "globalShortcut": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Utility",
      "copyright": "© 2024 Agent n8On",
      "icon": [
        "icons/icon.png",
        "icons/icon.ico"
      ],
      "identifier": "com.n8on.agent",
      "longDescription": "Local AI Assistant that works with Ollama and n8n. No cloud, no API keys needed.",
      "shortDescription": "Local AI Assistant",
      "targets": ["msi", "nsis"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "webviewInstallMode": {
          "type": "downloadBootstrapper"
        },
        "wix": null,
        "nsis": {
          "installerIcon": "icons/icon.ico",
          "headerImage": null,
          "sidebarImage": null,
          "installMode": "currentUser",
          "languages": ["English", "Russian"],
          "displayLanguageSelector": true
        }
      },
      "resources": [
        "../backend/**/*",
        "../requirements.txt"
      ],
      "externalBin": []
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Agent n8On",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "fileDropEnabled": true,
        "visible": false
      },
      {
        "label": "installer",
        "title": "Установка Agent n8On",
        "url": "setup.html",
        "width": 560,
        "height": 760,
        "minWidth": 520,
        "minHeight": 700,
        "resizable": false,
        "center": true,
        "decorations": true,
        "visible": false
      }
    ],
    "systemTray": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    }
  }
}
